{
  "addonType": "ingress",
  "annotations": {
    "architecture": "amd64,arm64"
  },
  "cloudTypes": [
    "all"
  ],
  "displayName": "Emissary Ingress",
  "charts": [
    "charts/emissary-crds-chart-4.1.0.tgz",
    "charts/emissary-ingress-4.1.0.tgz"
  ],
  "layer": "addon",
  "name": "emissary-ingress",
  "version": "4.1.0",
  "constraints": {
    "dependencies": [
      {
        "packName": "kubernetes",
        "layer": "k8s",
        "minVersion": "1.29",
        "maxVersion": "",
        "type": "optional"
      }
    ],
    "resources": [
      {
        "type": "cpu",
        "minLimit": 200,
        "components": [
          {
            "resourceRequestParamRef": "charts.emissary-ingress.resources.requests.cpu",
            "replicaCountParamRef": "charts.emissary-ingress.replicaCount",
            "scheduleType": "worker"
          }
        ]
      },
      {
        "type": "memory",
        "minLimit": 300,
        "components": [
          {
            "resourceRequestParamRef": "charts.emissary-ingress.resources.requests.memory",
            "replicaCountParamRef": "charts.emissary-ingress.replicaCount",
            "scheduleType": "worker"
          }
        ]
      }
    ]
  }
}